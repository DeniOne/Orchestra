{
  "name": "@orchestra/role-router",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && pnpm build:write-cjs-pkg",
    "build:write-cjs-pkg": "node ../../packages/_shared/write-cjs-package-json.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orchestra/domain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.6"
  }
}
