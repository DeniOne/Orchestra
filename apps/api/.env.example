# Orchestra API env vars
# PostgreSQL (docker-compose orchestra-postgres на порту 5433)
DATABASE_URL="postgresql://orchestra:orchestra@localhost:5433/orchestra"

# Event Bus (Wave 8c)
# REDIS_PORT=6380 по умолчанию (избегает конфликта с dmg-redis на 6379).
# См. docker-compose.yml в корне проекта.
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=
# REDIS_DB=0

# API
PORT=3001

# LLM Provider API keys (Wave 9/10). Заполни в .env (НЕ коммитить).
OPENAI_API_KEY=
GLM_API_KEY=
GEMINI_API_KEY=
MIMO_API_KEY=

# Base URL overrides. Для real-provider setup (Wave 10):
# - OPENAI_BASE_URL → OpenRouter (OpenAI-compatible, даёт доступ к anthropic/google/openai моделям)
# - MIMO_BASE_URL   → реальный MiMo endpoint
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_TIMEOUT_MS=30000
