# Orchestra API env vars
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orchestra"

# Event Bus (Wave 8c)
# REDIS_PORT=6380 по умолчанию (избегает конфликта с dmg-redis на 6379).
# См. docker-compose.yml в корне проекта.
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=
# REDIS_DB=0

# API
PORT=3001
